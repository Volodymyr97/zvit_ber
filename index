<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Варшава — Звіт Лютий / Березень 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0a0f;
    --bg2: #111118;
    --bg3: #18181f;
    --surface: #1e1e28;
    --border: rgba(255,255,255,0.07);
    --accent: #00e5a0;
    --accent2: #7c5cfc;
    --accent3: #ff6b4a;
    --accent4: #fbbf24;
    --text: #f0f0f5;
    --muted: #8888a0;
    --card-r: 16px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* BG noise texture */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  /* HERO */
  .hero {
    position: relative;
    padding: 80px 40px 60px;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: end;
    border-bottom: 0.5px solid var(--border);
  }

  .hero-eyebrow {
    font-family: 'Unbounded', sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-eyebrow::before { content: ''; display: inline-block; width: 24px; height: 1px; background: var(--accent); }

  .hero h1 {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-meta {
    font-size: 13px;
    color: var(--muted);
    margin-top: 16px;
  }

  .hero-verdict {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: var(--card-r);
    padding: 20px 24px;
    min-width: 240px;
    max-width: 280px;
  }
  .hero-verdict .vl { font-size: 11px; color: var(--muted); margin-bottom: 6px; letter-spacing: 0.05em; text-transform: uppercase; }
  .hero-verdict .vt { font-family: 'Unbounded', sans-serif; font-size: 14px; font-weight: 700; color: var(--accent); line-height: 1.4; }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,10,15,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--border);
  }
  nav ul {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    gap: 0;
    list-style: none;
  }
  nav a {
    display: block;
    padding: 14px 20px;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
    font-weight: 500;
  }
  nav a:hover { color: var(--text); }

  /* MAIN */
  main { max-width: 1100px; margin: 0 auto; padding: 60px 40px; }

  .section { margin-bottom: 80px; }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 0.5px solid var(--border);
  }
  .section-num {
    font-family: 'Unbounded', sans-serif;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .section-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* KPI GRID */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 48px;
  }
  .kpi {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--card-r);
    padding: 20px 20px 18px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .kpi:hover { border-color: rgba(255,255,255,0.15); }
  .kpi::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
  }
  .kpi.green::after { background: var(--accent); }
  .kpi.purple::after { background: var(--accent2); }
  .kpi.orange::after { background: var(--accent3); }
  .kpi.yellow::after { background: var(--accent4); }

  .kpi-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 10px; }
  .kpi-main { display: flex; align-items: baseline; gap: 6px; }
  .kpi-val { font-family: 'Unbounded', sans-serif; font-size: 28px; font-weight: 700; }
  .kpi.green .kpi-val { color: var(--accent); }
  .kpi.purple .kpi-val { color: var(--accent2); }
  .kpi.orange .kpi-val { color: var(--accent3); }
  .kpi.yellow .kpi-val { color: var(--accent4); }
  .kpi-unit { font-size: 14px; color: var(--muted); }
  .kpi-change { font-size: 12px; margin-top: 6px; }
  .up { color: var(--accent); }
  .dn { color: var(--accent3); }
  .kpi-from { font-size: 11px; color: var(--muted); margin-top: 2px; }

  /* CHARTS LAYOUT */
  .charts-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .chart-card {
    background: var(--bg2);
    border: 0.5px solid var(--border);
    border-radius: var(--card-r);
    padding: 24px;
  }
  .chart-card-title { font-family: 'Unbounded', sans-serif; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .chart-card-sub { font-size: 12px; color: var(--muted); margin-bottom: 20px; }
  .legend-row { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 16px; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--muted); }
  .legend-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }

  /* SOURCES BAR CHART */
  .source-list { display: flex; flex-direction: column; gap: 12px; }
  .source-row { }
  .source-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 5px; }
  .source-name { font-size: 13px; color: var(--text); }
  .source-nums { font-size: 12px; color: var(--muted); }
  .source-nums strong { color: var(--text); font-weight: 500; }
  .source-track { background: var(--surface); border-radius: 4px; height: 6px; overflow: hidden; }
  .source-fill-wrap { display: flex; height: 100%; gap: 2px; }
  .sf { height: 100%; border-radius: 3px; transition: width 0.6s ease; }

  /* SEGMENT CARDS */
  .seg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .seg-card {
    background: var(--bg2);
    border: 0.5px solid var(--border);
    border-radius: var(--card-r);
    padding: 24px;
  }
  .seg-icon { font-size: 20px; margin-bottom: 12px; }
  .seg-title { font-family: 'Unbounded', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 16px; }
  .seg-row-item { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 0.5px solid var(--border); font-size: 13px; }
  .seg-row-item:last-child { border-bottom: none; }
  .seg-row-item .slabel { color: var(--muted); }
  .seg-row-item .svals { display: flex; gap: 10px; }
  .feb { color: var(--muted); }
  .mar { color: var(--text); font-weight: 500; }
  .seg-conv { margin-top: 16px; padding: 12px 16px; border-radius: 10px; background: var(--surface); display: flex; justify-content: space-between; align-items: center; }
  .seg-conv .cv-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .seg-conv .cv-val { font-family: 'Unbounded', sans-serif; font-size: 18px; font-weight: 700; }
  .seg-conv .cv-delta { font-size: 11px; margin-top: 2px; }

  /* CPL TABLE */
  .cpl-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 24px; }
  .cpl-card {
    background: var(--bg2);
    border: 0.5px solid var(--border);
    border-radius: var(--card-r);
    padding: 20px;
  }
  .cpl-label { font-size: 11px; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 10px; }
  .cpl-val { font-family: 'Unbounded', sans-serif; font-size: 22px; font-weight: 700; }
  .cpl-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

  /* META LEADS */
  .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .meta-card {
    background: var(--bg2);
    border: 0.5px solid var(--border);
    border-radius: var(--card-r);
    padding: 24px;
  }
  .meta-month { font-family: 'Unbounded', sans-serif; font-size: 12px; font-weight: 700; margin-bottom: 4px; }
  .meta-total { font-size: 36px; font-weight: 300; margin-bottom: 20px; }
  .meta-total span { font-family: 'Unbounded', sans-serif; font-size: 36px; font-weight: 700; }
  .meta-forms { display: flex; flex-direction: column; gap: 8px; }
  .meta-form-row { display: flex; justify-content: space-between; align-items: center; font-size: 13px; padding: 6px 0; border-bottom: 0.5px solid var(--border); }
  .meta-form-row:last-child { border-bottom: none; }
  .meta-form-row .fn { color: var(--muted); }
  .meta-form-row .fv { font-family: 'Unbounded', sans-serif; font-size: 13px; font-weight: 700; }

  /* INSIGHTS */
  .insights-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .insight-card {
    background: var(--bg2);
    border: 0.5px solid var(--border);
    border-radius: var(--card-r);
    padding: 20px 22px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .insight-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
  .insight-body .ih { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
  .insight-body .ip { font-size: 12px; color: var(--muted); line-height: 1.5; }

  /* FOOTER */
  footer {
    border-top: 0.5px solid var(--border);
    padding: 32px 40px;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--muted);
  }
  footer strong { font-family: 'Unbounded', sans-serif; font-size: 11px; color: var(--accent); }

  /* SCROLL REVEAL */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; padding: 48px 20px 40px; }
    .hero-verdict { max-width: 100%; }
    nav ul { padding: 0 16px; gap: 0; overflow-x: auto; }
    main { padding: 40px 20px; }
    .kpi-grid { grid-template-columns: 1fr 1fr; }
    .charts-2col, .seg-grid, .meta-grid, .insights-grid, .cpl-grid { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 10px; padding: 24px 20px; text-align: center; }
  }
</style>
</head>
<body>

<header>
  <div class="hero">
    <div>
      <div class="hero-eyebrow">Аналітичний звіт · Польща</div>
      <h1>Варшава<br><em>Лют — Бер</em><br>2026</h1>
      <p class="hero-meta">Звернення · Записи · Конверсія · Візити · Реклама</p>
    </div>
    <div class="hero-verdict">
      <div class="vl">Головний висновок</div>
      <div class="vt">Березень сильніший не за рахунок обсягу — а за рахунок якості обробки та закриття в запис</div>
    </div>
  </div>

  <nav>
    <ul>
      <li><a href="#kpi">KPI</a></li>
      <li><a href="#channels">Канали</a></li>
      <li><a href="#visits">Візити</a></li>
      <li><a href="#segments">Сегменти</a></li>
      <li><a href="#meta">Meta Leads</a></li>
      <li><a href="#insights">Висновки</a></li>
    </ul>
  </nav>
</header>

<main>

  <!-- KPI -->
  <section class="section reveal" id="kpi">
    <div class="section-head">
      <span class="section-num">01</span>
      <span class="section-title">Ключові показники</span>
    </div>
    <div class="kpi-grid">
      <div class="kpi green">
        <div class="kpi-label">Первинних візитів</div>
        <div class="kpi-main"><span class="kpi-val">474</span></div>
        <div class="kpi-change up">+59 (+14.2%)</div>
        <div class="kpi-from">← 415 у лютому</div>
      </div>
      <div class="kpi purple">
        <div class="kpi-label">Записів</div>
        <div class="kpi-main"><span class="kpi-val">675</span></div>
        <div class="kpi-change up">+122 (+22.1%)</div>
        <div class="kpi-from">← 553 у лютому</div>
      </div>
      <div class="kpi orange">
        <div class="kpi-label">Загальна конверсія</div>
        <div class="kpi-main"><span class="kpi-val">45.0</span><span class="kpi-unit">%</span></div>
        <div class="kpi-change up">+8.4 п.п.</div>
        <div class="kpi-from">← 36.6% у лютому</div>
      </div>
      <div class="kpi yellow">
        <div class="kpi-label">Звернень</div>
        <div class="kpi-main"><span class="kpi-val">1 499</span></div>
        <div class="kpi-change dn">−11 (−0.8%)</div>
        <div class="kpi-from">← 1 511 у лютому</div>
      </div>
    </div>
  </section>

  <!-- CHANNELS -->
  <section class="section reveal" id="channels">
    <div class="section-head">
      <span class="section-num">02</span>
      <span class="section-title">Канали: звернення, записи, конверсія</span>
    </div>
    <div class="charts-2col">
      <div class="chart-card">
        <div class="chart-card-title">Звернення та записи по каналах</div>
        <div class="chart-card-sub">Абсолютні значення, лютий vs березень</div>
        <div class="legend-row">
          <div class="legend-item"><span class="legend-dot" style="background:#7c5cfc;"></span>Лют зверн.</div>
          <div class="legend-item"><span class="legend-dot" style="background:#4a30c0;"></span>Бер зверн.</div>
          <div class="legend-item"><span class="legend-dot" style="background:#00e5a0;"></span>Лют записи</div>
          <div class="legend-item"><span class="legend-dot" style="background:#008f60;"></span>Бер записи</div>
        </div>
        <div style="position:relative;width:100%;height:240px;">
          <canvas id="channelChart" role="img" aria-label="Звернення та записи по каналах КЦ, Лід форма, Чат">КЦ: зверн 407/480, записи 314/369. Лід форма: зверн 458/349, записи 57/82. Чат: зверн 646/669, записи 182/228.</canvas>
        </div>
      </div>
      <div class="chart-card">
        <div class="chart-card-title">Конверсія по каналах (%)</div>
        <div class="chart-card-sub">Звернення → запис, лютий vs березень</div>
        <div class="legend-row">
          <div class="legend-item"><span class="legend-dot" style="background:#ff6b4a;"></span>Лютий</div>
          <div class="legend-item"><span class="legend-dot" style="background:#fbbf24;"></span>Березень</div>
        </div>
        <div style="position:relative;width:100%;height:240px;">
          <canvas id="convChart" role="img" aria-label="Конверсія по каналах">КЦ 77%/77%. Лід форма 12%/24%. Чат 28%/34%. Разом 37%/45%.</canvas>
        </div>
      </div>
    </div>

    <!-- Conversion table inline -->
    <div class="chart-card" style="margin-top:16px;">
      <div class="chart-card-title" style="margin-bottom:16px;">Детальна таблиця конверсії</div>
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="border-bottom:0.5px solid var(--border);">
            <th style="text-align:left;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;text-transform:uppercase;letter-spacing:.06em;">Канал</th>
            <th style="text-align:right;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;">Зверн. лют</th>
            <th style="text-align:right;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;">Зверн. бер</th>
            <th style="text-align:right;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;">Записи лют</th>
            <th style="text-align:right;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;">Записи бер</th>
            <th style="text-align:right;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;">Конв. лют</th>
            <th style="text-align:right;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;">Конв. бер</th>
            <th style="text-align:right;padding:8px 10px;color:var(--muted);font-weight:400;font-size:11px;">Δ</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom:0.5px solid var(--border);">
            <td style="padding:10px;font-weight:500;">КЦ</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">406.9</td>
            <td style="padding:10px;text-align:right;">480.0</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">313.7</td>
            <td style="padding:10px;text-align:right;">369.3</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">77.1%</td>
            <td style="padding:10px;text-align:right;color:var(--accent);">76.9%</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">−0.2</td>
          </tr>
          <tr style="border-bottom:0.5px solid var(--border);">
            <td style="padding:10px;font-weight:500;">Лід форма</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">457.6</td>
            <td style="padding:10px;text-align:right;">348.6</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">56.9</td>
            <td style="padding:10px;text-align:right;">82.3</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">12.4%</td>
            <td style="padding:10px;text-align:right;color:var(--accent);">23.6%</td>
            <td style="padding:10px;text-align:right;color:var(--accent);">+11.2</td>
          </tr>
          <tr style="border-bottom:0.5px solid var(--border);">
            <td style="padding:10px;font-weight:500;">Чат</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">646.3</td>
            <td style="padding:10px;text-align:right;">668.7</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">182.4</td>
            <td style="padding:10px;text-align:right;">227.6</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">28.2%</td>
            <td style="padding:10px;text-align:right;color:var(--accent);">34.0%</td>
            <td style="padding:10px;text-align:right;color:var(--accent);">+5.8</td>
          </tr>
          <tr style="background:var(--surface);">
            <td style="padding:10px;font-weight:700;font-family:'Unbounded',sans-serif;font-size:12px;">Разом</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">1 510.7</td>
            <td style="padding:10px;text-align:right;font-weight:500;">1 499.3</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">553.0</td>
            <td style="padding:10px;text-align:right;font-weight:500;color:var(--accent);">675.1</td>
            <td style="padding:10px;text-align:right;color:var(--muted);">36.6%</td>
            <td style="padding:10px;text-align:right;font-weight:500;color:var(--accent);">45.0%</td>
            <td style="padding:10px;text-align:right;color:var(--accent);font-weight:500;">+8.4</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- VISITS / SOURCES -->
  <section class="section reveal" id="visits">
    <div class="section-head">
      <span class="section-num">03</span>
      <span class="section-title">Первинні візити: джерела</span>
